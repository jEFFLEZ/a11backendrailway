# Environment variables for A11 Backend
PORT=3000
HOST_SERVER=0.0.0.0
LLM_ROUTER_URL=http://127.0.0.1:4545
LLAMA_PORT=8080
LLAMA_BASE=http://127.0.0.1:8080
LOCAL_LLM_URL=http://127.0.0.1:8080
TTS_BASE_URL=
TTS_PORT=5002
TTS_MODELS_DIR=
TTS_MODEL_PATH=/app/apps/tts/fr_FR-siwis-medium.onnx
PIPER_BIN=
ENABLE_PIPER_HTTP=false
PIPER_START_CMD=
BACKEND=openai
OPENAI_API_KEY=your-openai-key
NEZ_TOKENS=your-nez-tokens
NEZ_ADMIN_TOKEN=your-admin-token
NEZ_ALLOWED_TOKEN=your-allowed-token
CORS_ORIGINS=https://funesterie.pro,https://your-netlify-site.netlify.app
A11_WORKSPACE_ROOT=/app
ONNX_MODEL_URL=https://<TON_ENDPOINT_R2>/a11-files/fr_FR-siwis-medium.onnx
QFLUSH_AUTO_START=false
QFLUSH_URL=
QFLUSH_REMOTE_URL=
QFLUSH_TOKEN=
QFLUSH_CHAT_FLOW=
QFLUSH_MEMORY_SUMMARY_FLOW=a11.memory.summary.v1
QFLUSH_EPHEMERAL_MEMORY_FLOW=a11.memory.ephemeral.v1
A11_EPHEMERAL_CHAT_TTL_SEC=7200
A11_EPHEMERAL_CHAT_CONTEXT_LIMIT=6

# Storage files (Cloudflare R2 / S3 compatible)
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=a11-files
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_PUBLIC_BASE_URL=https://files.example.com

# Email
EMAIL_FROM=A11 <onboarding@resend.dev>
RESEND_API_KEY=your-resend-key

# Slack alerts (optional)
SLACK_WEBHOOK_URL=
SLACK_NOTIFY_ERRORS=true

# OCR image preprocessing
IMAGE_OCR_ENABLED=true
IMAGE_OCR_MAX_BYTES=4194304
IMAGE_OCR_TARGET_BYTES=2097152
IMAGE_OCR_MAX_WIDTH=1600
IMAGE_OCR_MIN_WIDTH=960
IMAGE_OCR_TIMEOUT_MS=20000
